{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "photography",
  "main": "_worker.js",
  "compatibility_date": "2026-06-18",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    { "binding": "PHOTOS", "bucket_name": "photos" }
  ]
}
